		<!-- 左側邊欄 Treeview 鍵盤無障礙展開功能 -->
        <script>
            (function () {
                document.addEventListener('DOMContentLoaded', function () {
                    // 檢查是否有 treeview 元素
                    var treeviews = document.querySelectorAll('.treeview');
                    if (treeviews.length === 0) return;

                    // 找到第一層選單項目對應的 checkbox
                    function findParentCheckbox(leftDiv) {
                        // 向上找到 label
                        var label = leftDiv.closest('label');
                        if (!label) return null;

                        var forAttr = label.getAttribute('for');
                        if (!forAttr) return null;

                        return document.getElementById(forAttr);
                    }

                    // 檢查此項目是否有子選單
                    function hasSubMenu(checkbox) {
                        if (!checkbox) return false;
                        var parentLi = checkbox.closest('li');
                        if (!parentLi) return false;

                        // 檢查 li 內是否有直接子 ul 元素
                        var childUls = parentLi.children;
                        for (var i = 0; i < childUls.length; i++) {
                            if (childUls[i].tagName === 'UL') {
                                return true;
                            }
                        }
                        return false;
                    }

                    // 更新子選單項目的 tabindex
                    function updateSubMenuTabIndex() {
                        treeviews.forEach(function (treeview) {
                            var allLis = treeview.querySelectorAll('li');
                            allLis.forEach(function (li) {
                                var checkbox = li.querySelector(':scope > input[type="checkbox"]');
                                if (!checkbox) return;

                                // 找到此 li 內的直接子 ul
                                var childUls = li.children;
                                for (var i = 0; i < childUls.length; i++) {
                                    if (childUls[i].tagName === 'UL') {
                                        var subItems = childUls[i].querySelectorAll('.left_div');
                                        subItems.forEach(function (subItem) {
                                            if (checkbox.checked) {
                                                subItem.setAttribute('tabindex', '0');
                                            } else {
                                                subItem.setAttribute('tabindex', '-1');
                                            }
                                        });
                                    }
                                }
                            });
                        });
                    }

                    // 初始化時更新所有子選單的 tabindex
                    updateSubMenuTabIndex();

                    // 使用事件委派處理 focus 事件
                    document.addEventListener('focusin', function (event) {
                        var target = event.target;
                        if (!target.classList.contains('left_div')) return;
                        if (!target.closest('.treeview')) return;

                        var checkbox = findParentCheckbox(target);
                        if (checkbox && hasSubMenu(checkbox) && !checkbox.checked) {
                            checkbox.checked = true;
                            updateSubMenuTabIndex();
                        }
                    });

                    // 使用事件委派處理 keydown 事件
                    document.addEventListener('keydown', function (event) {
                        if (event.key !== 'Enter' && event.key !== ' ') return;

                        var target = event.target;
                        if (!target.classList.contains('left_div')) return;
                        if (!target.closest('.treeview')) return;

                        var checkbox = findParentCheckbox(target);
                        if (checkbox && hasSubMenu(checkbox)) {
                            // 切換展開/收合狀態
                            checkbox.checked = !checkbox.checked;
                            updateSubMenuTabIndex();
                        }
                    });

                    // 監聽所有 checkbox 的變化以更新 tabindex
                    var allCheckboxes = document.querySelectorAll('.treeview input[type="checkbox"]');
                    allCheckboxes.forEach(function (checkbox) {
                        checkbox.addEventListener('change', updateSubMenuTabIndex);
                    });
                });
            })();
        </script>
        <!-- 自動為所有外部連結添加「另開新視窗」提示 -->
        <script>
            (function () {
                // 等待 DOM 載入完成
                document.addEventListener('DOMContentLoaded', function () {
                    // 選取所有帶有 target="_blank" 的連結
                    var externalLinks = document.querySelectorAll('a[target="_blank"]');

                    externalLinks.forEach(function (link) {
                        // 檢查連結是否已經有「另開新視窗」相關文字
                        var linkText = link.textContent || '';
                        var hasWindowHint = linkText.includes('另開新視窗') ||
                            linkText.includes('(另開新視窗)') ||
                            link.querySelector('.visually-hidden');

                        // 如果還沒有提示，則添加
                        if (!hasWindowHint) {
                            // 創建視覺隱藏的提示文字
                            var span = document.createElement('span');
                            span.className = 'visually-hidden';
                            span.textContent = '（另開新視窗）';

                            // 將提示文字添加到連結末尾
                            link.appendChild(span);

                            // 如果連結沒有 title 屬性，添加一個
                            if (!link.getAttribute('title')) {
                                var linkContent = link.textContent.replace('（另開新視窗）', '').trim();
                                link.setAttribute('title', linkContent + '（另開新視窗）');
                            } else {
                                // 如果已有 title 但不包含「另開新視窗」，則補上
                                var currentTitle = link.getAttribute('title');
                                if (!currentTitle.includes('另開新視窗')) {
                                    link.setAttribute('title', currentTitle + '（另開新視窗）');
                                }
                            }

                            // 如果連結沒有 aria-label，使用 title 的值
                            if (!link.getAttribute('aria-label') && link.getAttribute('title')) {
                                link.setAttribute('aria-label', link.getAttribute('title'));
                            }
                        }
                    });
                });
            })();
        </script>

        <!-- Menu toggle 鍵盤無障礙支援 -->
        <script>
            (function () {
                document.addEventListener('DOMContentLoaded', function () {
                    var menuLabel = document.querySelector('label[for="drop"]');
                    var menuCheckbox = document.getElementById('drop');

                    if (menuLabel && menuCheckbox) {
                        // 按下 Enter 或 Space 時 toggle 選單
                        menuLabel.addEventListener('keydown', function (e) {
                            if (e.key === 'Enter' || e.key === ' ') {
                                e.preventDefault();
                                menuCheckbox.checked = !menuCheckbox.checked;
                                // 更新 aria-expanded 狀態
                                menuLabel.setAttribute('aria-expanded', menuCheckbox.checked);
                            }
                        });

                        // 點擊時也更新 aria-expanded 狀態
                        menuLabel.addEventListener('click', function () {
                            setTimeout(function () {
                                menuLabel.setAttribute('aria-expanded', menuCheckbox.checked);
                            }, 0);
                        });

                        // checkbox 狀態變化時更新 aria-expanded
                        menuCheckbox.addEventListener('change', function () {
                            menuLabel.setAttribute('aria-expanded', menuCheckbox.checked);
                        });
                    }
                });
            })();
        </script>

        <!-- Skip-link Accesskey 焦點導航修正：確保 Alt+C/U/Z 後焦點真正移至目標區塊 -->
        <script>
            (function () {
                document.addEventListener('DOMContentLoaded', function () {
                    // Accesskey 對應的目標 ID
                    var accesskeyMap = {
                        'c': 'main-content',
                        'u': 'navigation',
                        'z': 'contact'
                    };

                    // 方法一：攔截鍵盤 Alt+Key，直接 focus 目標元素
                    document.addEventListener('keydown', function (e) {
                        if (!e.altKey) return;
                        var key = e.key.toLowerCase();
                        var targetId = accesskeyMap[key];
                        if (!targetId) return;

                        e.preventDefault();
                        e.stopPropagation();
                        var target = document.getElementById(targetId);
                        if (target) {
                            target.setAttribute('tabindex', '-1');
                            target.focus();
                        }
                    });

                    // 方法二：點擊 skip-link 時也確保焦點移到目標
                    var skipLinks = document.querySelectorAll('.skip-link[href^="#"]');
                    skipLinks.forEach(function (link) {
                        link.addEventListener('click', function (e) {
                            e.preventDefault();
                            var targetId = this.getAttribute('href').substring(1);
                            var target = document.getElementById(targetId);
                            if (target) {
                                target.setAttribute('tabindex', '-1');
                                target.focus();
                            }
                        });
                    });
                });
            })();
        </script>

        <!-- 焦點離開漢堡選單時自動收合 (WCAG CS2240700E) -->
        <script>
            (function () {
                document.addEventListener('DOMContentLoaded', function () {
                    var menuCheckbox = document.getElementById('drop');
                    var mainMenu = document.getElementById('main-menu');
                    var menuLabel = document.querySelector('label[for="drop"]');
                    var tmenubox = document.querySelector('.tmenubox');

                    if (!menuCheckbox || !mainMenu || !menuLabel || !tmenubox) return;

                    // 當焦點離開選單區域時，自動收合選單
                    tmenubox.addEventListener('focusout', function () {
                        setTimeout(function () {
                            // 確認新的焦點目標不在選單區域內
                            if (menuCheckbox.checked && !tmenubox.contains(document.activeElement)) {
                                menuCheckbox.checked = false;
                                menuLabel.setAttribute('aria-expanded', 'false');

                                // 同時收合子選單的 checkbox
                                var subCheckboxes = tmenubox.querySelectorAll('input[type="checkbox"]');
                                subCheckboxes.forEach(function (cb) {
                                    cb.checked = false;
                                });
                            }
                        }, 0);
                    });

                    // 按 Escape 鍵時收合選單，並將焦點返回 Menu 按鈕
                    tmenubox.addEventListener('keydown', function (e) {
                        if (e.key === 'Escape' && menuCheckbox.checked) {
                            menuCheckbox.checked = false;
                            menuLabel.setAttribute('aria-expanded', 'false');

                            var subCheckboxes = tmenubox.querySelectorAll('input[type="checkbox"]');
                            subCheckboxes.forEach(function (cb) {
                                cb.checked = false;
                            });

                            menuLabel.focus();
                        }
                    });
                });
            })();
        </script>
    </form>
</body>
</html>
