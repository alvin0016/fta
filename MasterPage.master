    <style>
        /* Accesskey skip links (GN1240100E: 描述性文字 + 焦點時可見) */
        .skip-link {
            position: absolute;
            left: -9999px;
            top: -9999px;
            z-index: 9999;
            padding: 8px 16px;
            background: #1b3055;
            color: #ffffff;
            text-decoration: none;
            font-weight: 700;
            font-size: 1rem;
            border-radius: 0 0 4px 4px;
            border: 2px solid #ff8a00;
            white-space: nowrap;
        }

            .skip-link:focus,
            .skip-link:active {
                left: 16px;
                top: 0;
                outline: 3px solid #ff8a00;
                outline-offset: 2px;
            }

        .menu-skip {
            padding: 14px 20px;
        }

        /* 通用焦點樣式 - 為所有可聚焦元素添加高對比邊框 (WCAG CS2240700E) */
        button:focus,
        button:focus-visible,
        a:focus,
        a:focus-visible,
        input:focus,
        input:focus-visible,
        select:focus,
        select:focus-visible,
        textarea:focus,
        textarea:focus-visible,
        [tabindex]:focus,
        [tabindex]:focus-visible,
        .w3-button:focus,
        .w3-button:focus-visible,
        .w3-bar-item:focus,
        .w3-bar-item:focus-visible {
            outline: 3px solid #ff8a00 !important;
            outline-offset: 2px;
        }

        /* 為帶有 role="button" 的 div 元素添加焦點樣式 */
        div[role="button"]:focus,
        div[role="button"]:focus-visible {
            outline: 3px solid #ff8a00 !important;
            outline-offset: 2px;
        }

        /* 導覽選單下拉連結焦點樣式 - 加粗邊框並確保完整顯示 */
        nav ul ul a:focus,
        nav ul ul a:focus-visible,
        nav .sec_k a:focus,
        nav .sec_k a:focus-visible,
        nav .sec_c a:focus,
        nav .sec_c a:focus-visible {
            outline: 3px solid #ff8a00 !important;
            outline-offset: -2px;
            background-color: #fff8e6 !important;
            position: relative;
            z-index: 100;
        }

        /* 確保下拉選單容器不會裁切焦點框線 */
        nav ul ul,
        nav .sec_k,
        nav .sec_c {
            overflow: visible !important;
        }

            nav ul ul li,
            nav .sec_k li {
                overflow: visible !important;
            }

        /* 進口貨品通關作業要點連結焦點樣式 */
        .rd_top:focus,
        .rd_top:focus-visible,
        .rd_g:focus,
        .rd_g:focus-visible,
        .rd_m:focus,
        .rd_m:focus-visible {
            outline: 3px solid #ff8a00 !important;
            outline-offset: -2px;
            background-color: #fff8e6 !important;
            box-shadow: 0 0 0 3px #ff8a00 !important;
        }

        /* Hero Swiper 按鈕焦點樣式 - 確保四邊完整顯示 */
        .header-swiper .slide-link:focus,
        .header-swiper .slide-link:focus-visible,
        .header-swiper button:focus,
        .header-swiper button:focus-visible {
            outline: 3px solid #ff8a00 !important;
            outline-offset: -3px;
            position: relative;
            z-index: 10;
        }

        /* Swiper 分頁和導航按鈕焦點樣式 */
        .swiper-button-prev:focus,
        .swiper-button-prev:focus-visible,
        .swiper-button-next:focus,
        .swiper-button-next:focus-visible,
        .swiper-pagination-bullet:focus,
        .swiper-pagination-bullet:focus-visible {
            outline: 3px solid #ff8a00 !important;
            outline-offset: 2px;
        }

        /* ECA/FTA 簽訂國家卡片焦點樣式 - 加粗邊框並確保不被相鄰卡片遮蓋 */
        .country-part div[role="button"]:focus,
        .country-part div[role="button"]:focus-visible,
        .country-part .col-lg-3:focus,
        .country-part .col-lg-3:focus-visible {
            outline: 3px solid #ff8a00 !important;
            outline-offset: -3px;
            position: relative;
            z-index: 10;
            box-shadow: 0 0 0 3px #ff8a00 !important;
        }

        /* 確保國家卡片容器不會裁切焦點框線 */
        .country-part .row {
            overflow: visible !important;
        }

        .country-part .team-item {
            overflow: visible !important;
        }
        
        .menu-button {
            display: none;
        }

        @media (max-width: 768px) {
            .tmenubox {
                display: block;
                background-color: #e6f5ff;
                padding: 0px 20px 3px 27px;
                color: #1b3055;
                font-size: 1.25rem;
                text-decoration: none;
                border: none;
                font-weight: bold;
                line-height: 43px;
            }

            .menu-button {
                display: block;
                float: right;
            }
        }
    </style>



