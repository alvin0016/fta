<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.web>
    <compilation debug="true" targetFramework="4.8"/>
    <httpRuntime targetFramework="4.8"/>
    <!-- Globalization settings for UTF-8 encoding -->
    <globalization
      requestEncoding="utf-8"
      responseEncoding="utf-8"
      culture="zh-TW"
      uiCulture="zh-TW"
      fileEncoding="utf-8"/>
    <pages>
      <controls>
        <add tagPrefix="asp" namespace="System.Web.UI" assembly="System.Web.Extensions, Version=4.0.0.0, Culture=neutral, PublicKeyToken=31BF3856AD364E35"/>
      </controls>
    </pages>
	<!-- SiteMap configuration -->
    <siteMap defaultProvider="XmlSiteMapProvider" enabled="true">
      <providers>
        <clear/>
        <add name="XmlSiteMapProvider"
             type="System.Web.XmlSiteMapProvider"
             siteMapFile="Web.sitemap"
             securityTrimmingEnabled="false"/>
      </providers>
    </siteMap>
    <!-- Session 配置 - 啟用 CSRF 防護所需 -->
    <sessionState mode="InProc" cookieSameSite="Lax" cookieless="false" timeout="20"/>

    <!-- HttpCookie 設定 - 提升安全性 -->
    <httpCookies httpOnlyCookies="true" requireSSL="false" sameSite="Lax"/>
  </system.web>
  <system.webServer>
    <defaultDocument>
      <files>
        <clear/>
        <add value="Default.aspx"/>
        <add value="index.aspx"/>
      </files>
    </defaultDocument>
    <staticContent>
      <!-- Remove existing MIME types first to avoid duplicates -->
      <remove fileExtension=".woff"/>
      <remove fileExtension=".woff2"/>
      <mimeMap fileExtension=".woff" mimeType="application/font-woff"/>
      <mimeMap fileExtension=".woff2" mimeType="application/font-woff2"/>
    </staticContent>
    <modules runAllManagedModulesForAllRequests="true"/>

    <!-- 安全 HTTP Headers - CSRF 防護和其他安全增強 -->
    <httpProtocol>
      <customHeaders>
        <!-- X-Frame-Options: 防止點擊劫持 (Clickjacking) -->
        <add name="X-Frame-Options" value="SAMEORIGIN"/>
        <!-- X-Content-Type-Options: 防止 MIME 類型嗅探 -->
        <add name="X-Content-Type-Options" value="nosniff"/>
        <!-- X-XSS-Protection: 啟用瀏覽器的 XSS 過濾器 -->
        <add name="X-XSS-Protection" value="1; mode=block"/>
        <!-- Referrer-Policy: 控制 Referer Header 的發送 -->
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin"/>
        <!-- Content-Security-Policy: 根據專案實際使用的資源配置 -->
        <!-- 注意：已根據專案使用的 CDN 和內聯腳本進行調整 -->
        <add name="Content-Security-Policy" value="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://code.jquery.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://unpkg.com; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com data:; img-src 'self' https: data:; connect-src 'self' https://cdn.jsdelivr.net; frame-src 'self';"/>
      </customHeaders>
    </httpProtocol>
  </system.webServer>
  <appSettings>
    <add key="ValidationSettings:UnobtrusiveValidationMode" value="None"/>
  </appSettings>
</configuration>
